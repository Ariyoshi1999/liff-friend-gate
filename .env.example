# ─────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS (Edge Functions only — never expose to the browser)
# Set with:  supabase secrets set KEY=value
# ─────────────────────────────────────────────────────────────

# LINE Messaging API channel secret (used to verify webhook signatures)
LINE_CHANNEL_SECRET=your_line_channel_secret

# Namespacing tag for this app. One Supabase project can host several apps;
# each row in friend_status is scoped by this value.
PROJECT_TAG=myapp

# Provided automatically by Supabase to deployed Edge Functions:
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
# You do NOT need to set these by hand when deploying to Supabase.
